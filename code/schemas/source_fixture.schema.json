{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metabolicum-agentic-research/schemas/source_fixture.schema.json",
  "title": "Cached source fixture",
  "description": "Immutable cached-source fixture consumed by Hermes acceptance tests and Stage 2 extraction.",
  "type": "object",
  "required": [
    "schema_version",
    "source_id",
    "source_url",
    "source_type",
    "platform",
    "title",
    "retrieved_at",
    "published_at",
    "source_language",
    "license",
    "transcript_method",
    "transcript_text",
    "transcript_sha256",
    "synthetic",
    "verification_status"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "source_id": {
      "type": "string",
      "format": "uuid"
    },
    "source_url": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "enum": [
        "post",
        "video",
        "podcast",
        "blog",
        "paper"
      ]
    },
    "platform": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "retrieved_at": {
      "type": "string",
      "format": "date-time"
    },
    "published_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "source_language": {
      "type": "string"
    },
    "speaker_or_author": {
      "type": "string",
      "minLength": 1
    },
    "speaker_registry_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-z]+:[a-z0-9-]+$"
    },
    "license": {
      "type": [
        "string",
        "null"
      ]
    },
    "transcript_method": {
      "type": [
        "string",
        "null"
      ]
    },
    "transcript_text": {
      "type": "string",
      "minLength": 1
    },
    "transcript_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "expected_markers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "synthetic": {
      "type": "boolean",
      "description": "True if this fixture contains synthetic/fabricated data (not from a real source). Must be false for production use."
    },
    "verification_status": {
      "type": "string",
      "enum": ["verified_real_source", "synthetic_test_only", "unverified"],
      "description": "Verification status of the source. Production ingestion requires 'verified_real_source'."
    }
  }
}
