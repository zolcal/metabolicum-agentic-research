{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metabolicum-agentic-research/schemas/marker_recommendation.schema.json",
  "title": "MarkerRecommendation (Stage 2 structurer output)",
  "description": "Constrained-decoding target for the Stage 2 demographic structurer role. Source of truth: docs/agentic-workflow/04-research-agents-spec.md (MarkerRecommendation Pydantic contract). Suitable for llama-server response_format={type: json_schema}.",
  "type": "object",
  "required": [
    "applies_to_markers",
    "units",
    "direction",
    "claim_polarity",
    "population",
    "verbatim_quote",
    "source_id",
    "source_url",
    "source_type",
    "source_language",
    "retrieved_at",
    "speaker_or_author",
    "paradigm",
    "extraction_model",
    "extractor_confidence"
  ],
  "additionalProperties": false,
  "properties": {
    "applies_to_markers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "target_value": {
      "type": [
        "number",
        "null"
      ]
    },
    "target_range": {
      "type": [
        "array",
        "null"
      ],
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "number"
      }
    },
    "units": {
      "type": "string",
      "minLength": 1
    },
    "direction": {
      "type": "string",
      "enum": [
        "below",
        "above",
        "between",
        "at"
      ]
    },
    "claim_polarity": {
      "type": "string",
      "enum": [
        "supports",
        "refutes",
        "qualifies"
      ],
      "default": "supports"
    },
    "population": {
      "type": "object",
      "required": [
        "applies_to"
      ],
      "additionalProperties": false,
      "properties": {
        "applies_to": {
          "type": "string",
          "description": "'unspecified' when the source does not say."
        },
        "sex": {
          "type": [
            "string",
            "null"
          ]
        },
        "age_min": {
          "type": [
            "number",
            "null"
          ]
        },
        "age_max": {
          "type": [
            "number",
            "null"
          ]
        },
        "weight_min": {
          "type": [
            "number",
            "null"
          ]
        },
        "weight_max": {
          "type": [
            "number",
            "null"
          ]
        },
        "bmi_min": {
          "type": [
            "number",
            "null"
          ]
        },
        "bmi_max": {
          "type": [
            "number",
            "null"
          ]
        },
        "ethnicity": {
          "type": [
            "string",
            "null"
          ]
        },
        "cohort": {
          "type": [
            "string",
            "null"
          ]
        },
        "pregnancy_status": {
          "type": [
            "string",
            "null"
          ]
        },
        "comorbidity": {
          "type": [
            "string",
            "null"
          ]
        },
        "specimen": {
          "type": [
            "string",
            "null"
          ]
        },
        "method": {
          "type": [
            "string",
            "null"
          ]
        },
        "stratum": {
          "type": [
            "string",
            "null"
          ]
        },
        "population_scope": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "verbatim_quote": {
      "type": "string",
      "minLength": 1,
      "description": "At least one full sentence from the source. Must appear as a substring of the fetched source after whitespace normalization."
    },
    "source_id": {
      "type": "string",
      "format": "uuid"
    },
    "source_url": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "enum": [
        "post",
        "video",
        "podcast",
        "blog",
        "paper"
      ]
    },
    "source_language": {
      "type": "string",
      "default": "en",
      "description": "BCP 47 language tag of the source."
    },
    "translated_quote": {
      "type": [
        "string",
        "null"
      ]
    },
    "translation_method": {
      "type": "string",
      "enum": [
        "deepl",
        "local_model",
        "human",
        "none"
      ],
      "default": "none"
    },
    "retrieved_at": {
      "type": "string",
      "format": "date-time"
    },
    "speaker_or_author": {
      "type": "string",
      "minLength": 1
    },
    "speaker_registry_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[a-z]+:[a-z0-9-]+$",
      "description": "Resolved \u00a716 registry id when known."
    },
    "cited_paper": {
      "type": [
        "object",
        "null"
      ],
      "required": [
        "raw_reference"
      ],
      "additionalProperties": false,
      "properties": {
        "raw_reference": {
          "type": "string",
          "minLength": 1
        },
        "pmid": {
          "type": [
            "string",
            "null"
          ]
        },
        "doi": {
          "type": [
            "string",
            "null"
          ]
        },
        "title": {
          "type": [
            "string",
            "null"
          ]
        },
        "authors_short": {
          "type": [
            "string",
            "null"
          ]
        },
        "year": {
          "type": [
            "integer",
            "null"
          ]
        },
        "journal": {
          "type": [
            "string",
            "null"
          ]
        },
        "resolved": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "paradigm": {
      "type": "string",
      "enum": [
        "SM",
        "RC",
        "MO"
      ]
    },
    "extraction_model": {
      "type": "string",
      "minLength": 1,
      "description": "Endpoint role name + concrete model id, e.g. 'extractor:qwen-3.6-27b-mtp'."
    },
    "extractor_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
