# Copy this file to secrets/.env and fill in the values.
# The .env file is gitignored. The .env.example file lists variable names only,
# never literal keys.

# ─── LLM endpoints (config/llm-endpoints.yaml resolves api_key_env to these) ──

# OpenRouter — single key for council reviewer (Gemini) + decider (GPT) +
# any reserve endpoints (Claude, DeepSeek, Kimi).
OPENROUTER_API_KEY=

# Google AI Studio — Gemini direct (currently used for embeddings).
GOOGLE_API_KEY=

# Alibaba DashScope (Singapore workspace) — cloud Qwen 3.7 Max,
# Alibaba-family vote in the Stage 3 council.
DASHSCOPE_API_KEY=

# OpenAI direct (optional; not used by default — council goes through OpenRouter).
OPENAI_API_KEY=

# ─── Supabase (metabolicum-agentic-research project) ─────────────────────────

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# ─── External data services ──────────────────────────────────────────────────

# YouTube Data API v3 — used by youtube-mcp (10k unit/day free quota).
YOUTUBE_API_KEY=

# PubMed E-utilities — optional NCBI API key for higher rate limits.
NCBI_API_KEY=

# Crossref — optional polite-pool token (mailto string).
CROSSREF_MAILTO=

# DeepL — translation MCP; deferred per spec, leave blank until multilingual
# discovery activates.
DEEPL_API_KEY=

# ─── Telegram gateway (out of scope for first acceptance pass) ───────────────

TELEGRAM_BOT_TOKEN=
# Comma-separated list of authorized chat ids that may enqueue tasks.
TELEGRAM_ALLOWED_CHAT_IDS=

# ─── Hermes (filled in once B1/B2 are cleared) ───────────────────────────────

# Hermes version tag or commit hash, also pinned in config/hermes-version.txt.
HERMES_VERSION=
